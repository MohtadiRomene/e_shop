### Application
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=replace-with-a-64-char-random-secret

### Doctrine
DATABASE_URL="mysql://app:replace-db-password@db:3306/e_shop?serverVersion=8.0.32&charset=utf8mb4"

### Mailer
MAILER_DSN=smtp://replace-user:replace-password@smtp.example.com:587

### Security behind reverse proxy / load balancer
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
TRUSTED_HOSTS='^e-shop\\.example\\.com$'
