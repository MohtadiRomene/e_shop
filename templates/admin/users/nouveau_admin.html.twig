{% extends 'admin/base.html.twig' %}

{% block title %}Nouvel admin - Administration{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">Créer un administrateur</h1>
    <a class="btn btn-outline-dark rounded-0" href="{{ path('app_admin') }}">
        Retour
    </a>
</div>

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }} rounded-0">{{ message }}</div>
    {% endfor %}
{% endfor %}

<div class="card rounded-0">
    <div class="card-body">
        {{ form_start(form) }}

        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_label(form.email) }}
                {{ form_widget(form.email) }}
                <div class="text-danger small">{{ form_errors(form.email) }}</div>
            </div>
            <div class="col-md-6 mb-3">
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom) }}
                <div class="text-danger small">{{ form_errors(form.nom) }}</div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                {{ form_label(form.tel) }}
                {{ form_widget(form.tel) }}
                <div class="text-danger small">{{ form_errors(form.tel) }}</div>
            </div>
            <div class="col-md-6 mb-3">
                {{ form_label(form.adresse) }}
                {{ form_widget(form.adresse) }}
                <div class="text-danger small">{{ form_errors(form.adresse) }}</div>
            </div>
        </div>

        <div class="mb-3">
            {{ form_label(form.plainPassword) }}
            {{ form_widget(form.plainPassword) }}
            <div class="text-danger small">{{ form_errors(form.plainPassword) }}</div>
        </div>

        <button class="btn btn-dark rounded-0" type="submit">
            Créer l’admin
        </button>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

