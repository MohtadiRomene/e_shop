APP_ENV=prod
APP_DEBUG=0
APP_SECRET=replace-with-a-long-random-secret
APP_VERSION=1.0.0

MYSQL_ROOT_PASSWORD=change-me-root

DB_HOST=db
DB_PORT=3306
DB_USER=app
DB_PASSWORD=change-me
DB_NAME=e_shop

DATABASE_URL=mysql://app:change-me@db:3306/e_shop?serverVersion=8.0.32&charset=utf8mb4
MAILER_DSN=null://null

TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
TRUSTED_HOSTS=^localhost$

RUN_MIGRATIONS=0
MIGRATIONS_STRICT=0
HTTP_PORT=8080

# Local only: include local MySQL service
COMPOSE_PROFILES=local
