project_name               = "e-shop"
environment                = "prod"
aws_region                 = "eu-west-1"
vpc_cidr                   = "10.30.0.0/16"
availability_zones         = ["eu-west-1a", "eu-west-1b", "eu-west-1c"]
public_subnet_cidrs        = ["10.30.0.0/20", "10.30.16.0/20", "10.30.32.0/20"]
private_subnet_cidrs       = ["10.30.64.0/20", "10.30.80.0/20", "10.30.96.0/20"]
db_subnet_cidrs            = ["10.30.128.0/24", "10.30.129.0/24", "10.30.130.0/24"]
rds_instance_class         = "db.t4g.medium"
rds_allocated_storage      = 100
rds_max_allocated_storage  = 500
rds_db_name                = "e_shop"
rds_username               = "eshop_admin"
rds_backup_retention_days  = 14
node_instance_types        = ["t3.large"]
node_desired_size          = 3
node_min_size              = 3
node_max_size              = 8
github_oidc_provider_arn   = "arn:aws:iam::<account-id>:oidc-provider/token.actions.githubusercontent.com"
github_repo                = "your-org/e_shop"
